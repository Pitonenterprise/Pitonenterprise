# OpenAI — for the AI Saree Assistant chatbot
OPENAI_API_KEY=sk-proj-...
# Optional override; defaults to gpt-4o-mini (cheap + fast for chat)
# OPENAI_MODEL=gpt-4o-mini

# Supabase — leave blank to run in DEMO_MODE (uses local seed data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Store branding
NEXT_PUBLIC_STORE_NAME=Pitonenterprise
NEXT_PUBLIC_STORE_WHATSAPP=+919999999999

# Set to "true" to run with built-in seed data and skip Supabase
DEMO_MODE=true

# Admin password (demo only — replace with proper auth for production)
ADMIN_PASSWORD=admin123
