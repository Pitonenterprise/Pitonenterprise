# ============================================================
#  Pitonenterprise — environment variables (EXAMPLE / placeholders)
#  Copy to .env.local and fill in real values. NEVER commit .env.local.
#  See Doc/ENV.md for what each variable does.
# ============================================================

# --- Database (Payload → Supabase Postgres) ---
# Supabase: Project Settings → Database → Connection string → Session pooler (port 5432).
DATABASE_URI=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# --- Payload ---
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# --- Site ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=Pitonenterprise

# --- Supabase (storage / client) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (international payments) — added in Phase 2 ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Razorpay (India payments) — added in Phase 2 ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Email (Resend) — OTP verification + order emails ---
# https://resend.com. Until set, OTP codes print to the server console (dev).
RESEND_API_KEY=
EMAIL_FROM=Piton Enterprise <onboarding@resend.dev>

# --- OpenAI (optional — only if AI Saree Assistant is enabled later) ---
# OPENAI_API_KEY=
